# Mission Control — Environment Variables
# Copy to .env and fill in values

# ── App Mode ──────────────────────────────────────────────────────
# Set to "false" for production (enables auth, scopes to client companies)
DEMO_MODE=true
DEBUG=false
PORT=8000

# ── GitHub OAuth ──────────────────────────────────────────────────
# Create at: https://github.com/settings/developers > New OAuth App
# Homepage URL: https://your-app.onrender.com
# Callback URL: https://your-app.onrender.com/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Session Security ─────────────────────────────────────────────
# Random secret for signing session cookies (use: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=dev-secret-change-me

# ── Access Control ───────────────────────────────────────────────
# Comma-separated GitHub usernames allowed to access the dashboard
# Leave empty to allow any authenticated GitHub user
ALLOWED_USERS=

# ── Email Auth ─────────────────────────────────────────────────
# Comma-separated emails that can create accounts via email/password
# Leave empty to disable email registration entirely
ALLOWED_EMAILS=

# ── GitHub API (Website Builder) ─────────────────────────────────
# Personal access token with repo scope for US-Websites org
GITHUB_TOKEN=

# ── Render API (Monitoring) ──────────────────────────────────────
# Render API key from dashboard.render.com > Account Settings > API Keys
RENDER_API_KEY=

# ── Render Service IDs ───────────────────────────────────────────
# Service IDs for monitoring deploys (find in Render dashboard URLs)
RENDER_SERVICE_EXTERIORS=
RENDER_SERVICE_DRYWALL=
RENDER_SERVICE_MC=

# ── Anthropic API (Website Builder AI + Monday Morning Brief) ────
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
